# Strava API application credentials.
# Create an app at https://www.strava.com/settings/api to obtain these.
# Copy this file to ".env" (loaded automatically) OR export these in your shell.

# Required for `strava auth login` and token refresh:
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Optional: supply tokens directly for headless / agent setups instead of
# running `strava auth login`. A refresh token is enough (access tokens are
# auto-derived); an access token alone also works until it expires.
STRAVA_REFRESH_TOKEN=
STRAVA_ACCESS_TOKEN=

# Optional: override where config/tokens and cache are stored.
# STRAVA_CONFIG_DIR=
# STRAVA_CACHE_DIR=

# Optional: redirect port used by the one-time OAuth login flow (default 41734).
# STRAVA_OAUTH_PORT=41734
